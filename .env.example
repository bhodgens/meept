# Meept Environment Configuration
# Copy to .env and fill in values

# LLM Configuration
MEEPT_LLM_BASE_URL=http://localhost:11434/v1
MEEPT_LLM_API_KEY=
MEEPT_LLM_MODEL=llama3.2

# Telegram (optional)
MEEPT_TELEGRAM_TOKEN=
MEEPT_TELEGRAM_CREATOR_ID=

# Web UI (optional)
MEEPT_WEB_SECRET_KEY=
MEEPT_WEB_HOST=127.0.0.1
MEEPT_WEB_PORT=8420

# Google Calendar (optional)
MEEPT_GCAL_CREDENTIALS_FILE=
