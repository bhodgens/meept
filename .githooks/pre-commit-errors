#!/bin/bash
# Pre-commit hook that checks for common error handling anti-patterns
#
# This hook detects:
# - Ignored errors (_ = someFunc())
# - Bare returns without error context
# - panic(err) in non-test code
# - fmt.Errorf without %w for wrapping
# - Error assigned but not returned
#
# Installation: Included in .githooks/pre-commit

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BLUE}  Checking error handling patterns${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

# Get staged Go files (excluding test files)
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=d 2>/dev/null | grep '\.go$' | grep -v '_test\.go$' || true)

if [ -z "$STAGED_GO_FILES" ]; then
  echo -e "${GREEN}✅ No Go source files staged${NC}"
  exit 0
fi

cd "$(git rev-parse --show-toplevel)"

ISSUES_FOUND=false
ISSUE_COUNT=0

echo "Checking files:"
echo "$STAGED_GO_FILES" | sed 's/^/  /'
echo ""

for file in $STAGED_GO_FILES; do
  if [ ! -f "$file" ]; then
    continue
  fi

  # Skip generated code
  if grep -q "^// Code generated" "$file" 2>/dev/null; then
    continue
  fi

  FILE_ISSUES=""

  # Check 1: Ignored errors with _ =
  IGNORED_ERRORS=$(grep -n "_ = " "$file" 2>/dev/null | grep -v "// " || true)
  if [ -n "$IGNORED_ERRORS" ]; then
    # Filter out known safe patterns (context.WithoutCancel, etc.)
    IGNORED_ERRORS=$(echo "$IGNORED_ERRORS" | grep -vE "WithoutCancel|WithoutTimeout|WithoutDeadline" || true)
    if [ -n "$IGNORED_ERRORS" ]; then
      FILE_ISSUES="${FILE_ISSUES}  ⚠️  Ignored errors (_ =):\n${IGNORED_ERRORS}\n\n"
    fi
  fi

  # Check 2: panic(err) usage
  PANIC_CALLS=$(grep -n "panic(err)" "$file" 2>/dev/null | grep -v "// " || true)
  if [ -n "$PANIC_CALLS" ]; then
    FILE_ISSUES="${FILE_ISSUES}  ⚠️  panic(err) found (should use structured error handling):\n${PANIC_CALLS}\n\n"
  fi

  # Check 3: fmt.Errorf without %w (error wrapping)
  # Look for fmt.Errorf that return a variable without wrapping it
  UNWRAPPED_ERRORS=$(grep -n 'fmt\.Errorf(' "$file" 2>/dev/null | grep -v '%w' | grep -v '// ' || true)
  if [ -n "$UNWRAPPED_ERRORS" ]; then
    # Filter out cases where wrapping isn't needed (new errors, not wrapping)
    UNWRAPPED_ERRORS=$(echo "$UNWRAPPED_ERRORS" | grep -vE 'failed to|unable to|cannot|error' || true)
    if [ -n "$UNWRAPPED_ERRORS" ]; then
      FILE_ISSUES="${FILE_ISSUES}  ℹ️  fmt.Errorf without %w (consider wrapping):\n${UNWRAPPED_ERRORS}\n\n"
    fi
  fi

  # Check 4: // TODO without error return consideration (informational)
  # TODO_ERRORS=$(grep -n "// TODO" "$file" 2>/dev/null | head -5 || true)

  if [ -n "$FILE_ISSUES" ]; then
    echo -e "${YELLOW}⚠️  $file:${NC}"
    echo -e "$FILE_ISSUES"
    ISSUES_FOUND=true
    ISSUE_COUNT=$((ISSUE_COUNT + 1))
  fi
done

if [ "$ISSUES_FOUND" = true ]; then
  echo ""
  echo -e "${YELLOW}Summary: Found $ISSUE_COUNT file(s) with potential error handling issues${NC}"
  echo ""
  echo -e "${BLUE}Error handling best practices (CLAUDE.md):${NC}"
  echo ""
  echo "  // Wrap errors with context:"
  echo "  if err != nil {"
  echo "      return fmt.Errorf('process file: %w', err)"
  echo "  }"
  echo ""
  echo "  // Don't ignore errors:"
  echo "  if _, err := doSomething(); err != nil {  // NOT: _ = doSomething()"
  echo "      return err"
  echo "  }"
  echo ""
  echo "  // Avoid panic for recoverable errors:"
  echo "  // return err, not panic(err)"
  echo ""

  # Exit with error only for ignored errors (most critical)
  if echo "$STAGED_GO_FILES" | xargs -I{} grep -l "_ = " {} 2>/dev/null | grep -qvE "WithoutCancel|WithoutTimeout"; then
    echo -e "${RED}❌ Commit blocked: ignored errors detected${NC}"
    echo ""
    exit 1
  fi

  echo -e "${YELLOW}⚠️  These are warnings. Review and fix before committing.${NC}"
  echo ""
else
  echo -e "${GREEN}✅ Error handling patterns look good${NC}"
fi

exit 0
