#!/bin/bash
# Pre-commit hook to ensure feature documentation is updated for code changes
#
# This hook:
# 1. Detects code changes in feature-related directories
# 2. Checks if corresponding feature documentation exists or needs updating
# 3. Uses aider with glm-5.2 to help generate documentation when needed
#
# Installation:
#   chmod +x .git/hooks/pre-commit-feature-docs
#   # Then source from your main pre-commit hook:
#   .git/hooks/pre-commit-feature-docs || exit 1

set -e

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Capitalize the first letter of $1 (POSIX-compatible; ${var^} is bash 4+).
capitalize_first() {
  local s="$1"
  if [ -z "$s" ]; then
    echo ""
    return
  fi
  # Uppercase first char via tr, keep the rest.
  printf '%s%s\n' "$(printf '%s' "${s:0:1}" | tr '[:lower:]' '[:upper:]')" "${s:1}"
}

# Configuration
AIDER_MODEL="${AIDER_MODEL:-glm-5.2}"
# Use project-level aider config if it exists, otherwise user-level
PROJECT_AIDER_CONFIG="$(git rev-parse --show-toplevel 2>/dev/null)/.aider.conf.yml"
if [ -f "$PROJECT_AIDER_CONFIG" ]; then
  AIDER_CONFIG="$PROJECT_AIDER_CONFIG"
else
  AIDER_CONFIG="${HOME}/.aider.conf.yml"
fi
FEATURE_DOCS_DIR="docs/workflows"
CONCEPTS_DIR="docs/concepts"
REFERENCE_DIR="docs/reference"

# Track features needing docs (space-separated list)
FEATURES_NEEDING_DOCS=""

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BLUE}  Feature Documentation Pre-Commit Check${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

# Get list of staged files (excluding deleted files)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=d 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
  echo -e "${GREEN}✅ No staged changes to check${NC}"
  exit 0
fi

# Function to determine if a file is documentation
is_documentation() {
  local file="$1"
  if [[ "$file" == docs/*.md ]] || [[ "$file" == docs/*.mdx ]]; then
    return 0
  fi
  return 1
}

# Function to determine if a file is a feature implementation
is_feature_code() {
  local file="$1"

  # Skip test files, config files, and non-code files
  if [[ "$file" == *"_test.go" ]] || \
     [[ "$file" == "config/"* ]] || \
     [[ "$file" == "~/.meept/"* ]] || \
     [[ "$file" == "menubar/"* ]] || \
     [[ "$file" == "ui/"* ]] || \
     [[ "$file" == "scratch/"* ]] || \
     [[ "$file" == *".json5" ]] || \
     [[ "$file" == *".json" ]] || \
     [[ "$file" == *".yaml" ]] || \
     [[ "$file" == *".yml" ]] || \
     [[ "$file" == "go.mod" ]] || \
     [[ "$file" == "go.sum" ]] || \
     [[ "$file" == "Makefile" ]] || \
     [[ "$file" == "CLAUDE.md" ]] || \
     [[ "$file" == "README.md" ]] || \
     [[ "$file" == *"/vendor/"* ]]; then
    return 1
  fi

  # Check if it's a Go source file in internal/cmd/pkg
  if [[ "$file" == "internal/"*.go ]] || \
     [[ "$file" == "cmd/"*.go ]] || \
     [[ "$file" == "pkg/"*.go ]]; then
    return 0
  fi

  # Check for other feature-related files
  if [[ "$file" == "internal/"* ]] || [[ "$file" == "cmd/"* ]]; then
    return 0
  fi

  return 1
}

# Function to extract feature name from file path
extract_feature_name() {
  local file="$1"
  local dir=$(dirname "$file" | sed 's|^internal/||' | sed 's|^cmd/||')
  local base_feature=$(echo "$dir" | cut -d'/' -f1)

  # Map common directories to feature names
  case "$base_feature" in
    "agent") echo "agent-orchestration" ;;
    "llm") echo "llm-management" ;;
    "memory") echo "memory" ;;
    "security") echo "security" ;;
    "tools") echo "tool-routing" ;;
    "skills") echo "skills" ;;
    "scheduler") echo "job-scheduling" ;;
    "comm") echo "external-integrations" ;;
    "calendar") echo "external-integrations" ;;
    "stt") echo "speech-to-text" ;;
    "tts") echo "tts" ;;
    "runtime") echo "runtime" ;;
    "pty") echo "pty-streaming" ;;
    "code") echo "code-intelligence" ;;
    "selfimprove") echo "self-improvement" ;;
    "project") echo "project-context" ;;
    "daemon") echo "daemon" ;;
    *) echo "$base_feature" ;;
  esac
}

# Function to check if feature documentation exists
feature_doc_exists() {
  local feature="$1"
  local doc_file="${FEATURE_DOCS_DIR}/${feature}.md"

  if [ -f "$doc_file" ]; then
    return 0
  fi
  return 1
}

# Function to check if documentation was modified in this commit
doc_modified_in_commit() {
  local feature="$1"
  local doc_file="${FEATURE_DOCS_DIR}/${feature}.md"
  local concept_file="${CONCEPTS_DIR}/${feature}.md"
  local ref_file="${REFERENCE_DIR}/${feature}.md"

  # Check if any doc file is staged
  if echo "$STAGED_FILES" | grep -q "^${doc_file}$" || \
     echo "$STAGED_FILES" | grep -q "^${concept_file}$" || \
     echo "$STAGED_FILES" | grep -q "^${ref_file}$"; then
    return 0
  fi

  # Also check for index files
  if [ "$feature" == "daemon" ] || [ "$feature" == "runtime" ] || [ "$feature" == "pty-streaming" ]; then
    # These might be documented in other files
    return 0
  fi

  return 1
}

# Function to check if feature is already in the list
feature_in_list() {
  local feature="$1"
  local list="$2"
  echo " $list " | grep -q " $feature "
}

# Function to generate documentation suggestion using aider
generate_doc_suggestion() {
  local feature="$1"
  local changed_files="$2"

  echo -e "${YELLOW}📝 Would you like to generate documentation using aider?${NC}"
  echo -e "   This will create ${FEATURE_DOCS_DIR}/${feature}.md"
  echo ""
  read -p "   Generate documentation? (y/n): " -n 1 -r
  echo ""

  if [[ $REPLY =~ ^[Yy]$ ]]; then
    # Check if aider is installed
    if ! command -v aider &> /dev/null; then
      echo -e "${RED}❌ aider is not installed. Please install with:${NC}"
      echo -e "   pip install aider-chat"
      echo ""
      return 1
    fi

    # Create aider config if it doesn't exist
    if [ ! -f "$AIDER_CONFIG" ]; then
      cat > "$AIDER_CONFIG" << 'EOF'
model: glm-5.2
auto-accept: false
show-diffs: true
EOF
      echo -e "${BLUE}Created aider config at ${AIDER_CONFIG}${NC}"
    fi

    # Build the list of changed files for aider to analyze
    local aider_files=""
    for file in $changed_files; do
      if [ -f "$file" ]; then
        aider_files="$aider_files $file"
      fi
    done

    # Create a temporary documentation template
    local temp_doc="/tmp/feature-doc-${feature}.md"
    cat > "$temp_doc" << EOF
# $(capitalize_first "$feature")

## Overview
<!-- TODO: Describe what this feature does and why it exists -->

## Problem
<!-- TODO: What problem does this feature solve? -->

## Behavior
<!-- TODO: Describe how the feature works -->

### Key Components
<!-- TODO: List main components and their responsibilities -->

### Configuration
<!-- TODO: Show configuration options with examples -->
\`\`\`json5
{
  // Example configuration
}
\`\`\`

### Observability
<!-- TODO: Describe logging, metrics, and debugging info -->

## Edge Cases
<!-- TODO: Document edge cases and how they're handled -->

EOF

    echo -e "${BLUE}🤖 Running aider with ${AIDER_MODEL} to analyze changes...${NC}"
    echo ""

    # Run aider to help generate documentation
    # Note: We use --no-auto-commit to prevent aider from committing
    cd "$(git rev-parse --show-toplevel)"
    aider --model "$AIDER_MODEL" \
          --no-auto-commit \
          --message "Generate feature documentation for ${feature} based on these changed files.

The documentation should follow the existing format in docs/workflows/. Include:
1. Overview of what the feature does
2. The problem it solves
3. How it behaves (key components, flow)
4. Configuration options
5. Observability (logging, metrics)
6. Edge cases

Changed files to analyze:
$changed_files

Output the documentation in markdown format." \
          $aider_files "$temp_doc" 2>/dev/null || true

    echo ""
    echo -e "${GREEN}✅ Documentation draft created at: ${temp_doc}${NC}"
    echo -e "${YELLOW}📋 Next steps:${NC}"
    echo "   1. Review and edit: ${temp_doc}"
    echo "   2. Copy to: ${FEATURE_DOCS_DIR}/${feature}.md"
    echo "   3. Stage the documentation: git add ${FEATURE_DOCS_DIR}/${feature}.md"
    echo "   4. Re-run commit: git commit"
    echo ""

    # Open the file for review if possible
    if command -v open &> /dev/null; then
      open "$temp_doc" 2>/dev/null || true
    elif command -v xdg-open &> /dev/null; then
      xdg-open "$temp_doc" 2>/dev/null || true
    fi

    return 0
  fi

  return 1
}

# Function to suggest manual documentation
suggest_manual_doc() {
  local feature="$1"
  local doc_file="${FEATURE_DOCS_DIR}/${feature}.md"

  echo -e "${YELLOW}⚠️  No documentation found for feature: ${feature}${NC}"
  echo ""
  echo -e "   Suggested documentation file: ${doc_file}"
  echo ""
  echo -e "${BLUE}Documentation template:${NC}"
  echo '---'
  echo "title: $(capitalize_first "$feature")"
  echo '---'
  echo ""
  echo "# $(capitalize_first "$feature")"
  echo ""
  echo "## Overview"
  echo "<!-- What does this feature do? -->"
  echo ""
  echo "## Problem"
  echo "<!-- What problem does it solve? -->"
  echo ""
  echo "## Behavior"
  echo "<!-- How does it work? -->"
  echo ""
  echo "## Configuration"
  echo "<!-- Configuration options -->"
  echo ""
  echo "## Edge Cases"
  echo "<!-- Important edge cases -->"
  echo ""
  echo "---"
  echo ""

  echo -e "${GREEN}📋 ACTION REQUIRED:${NC}"
  echo "   Option 1: Create documentation at ${doc_file}"
  echo "   Option 2: Update existing docs if feature already documented elsewhere"
  echo "   Option 3: Use aider to help generate docs (run: aider --model glm-5.2)"
  echo "   Option 4: Skip this check with --no-verify (not recommended)"
  echo ""
}

# Main check loop
echo -e "${BLUE}Analyzing staged changes...${NC}"
echo ""

FILES_NEEDING_DOCS=""

for file in $STAGED_FILES; do
  # Skip documentation files themselves
  if is_documentation "$file"; then
    continue
  fi

  # Check if it's a feature code file
  if is_feature_code "$file"; then
    feature=$(extract_feature_name "$file")

    # Check if documentation exists or was modified
    if ! doc_modified_in_commit "$feature"; then
      if ! feature_doc_exists "$feature"; then
        # Track this feature as needing docs (avoid duplicates)
        if ! feature_in_list "$feature" "$FEATURES_NEEDING_DOCS"; then
          FEATURES_NEEDING_DOCS="$FEATURES_NEEDING_DOCS $feature"
        fi
        # Track files needing docs
        if [ -z "$FILES_NEEDING_DOCS" ]; then
          FILES_NEEDING_DOCS="$file"
        elif ! echo "$FILES_NEEDING_DOCS" | grep -q "$file"; then
          FILES_NEEDING_DOCS="$FILES_NEEDING_DOCS $file"
        fi
      fi
    fi
  fi
done

# Report findings
if [ -n "$FEATURES_NEEDING_DOCS" ]; then
  echo ""
  echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${YELLOW}  Documentation Updates Needed${NC}"
  echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""

  # Convert space-separated list to individual items
  for feature in $FEATURES_NEEDING_DOCS; do
    if [ -n "$feature" ]; then
      suggest_manual_doc "$feature"
      echo ""
    fi
  done

  # Offer to use aider if single feature
  feature_count=$(echo "$FEATURES_NEEDING_DOCS" | wc -w | tr -d ' ')
  if [ "$feature_count" -eq 1 ]; then
    feature=$(echo "$FEATURES_NEEDING_DOCS" | tr -d ' ')
    generate_doc_suggestion "$feature" "$FILES_NEEDING_DOCS"
  elif [ "$feature_count" -gt 1 ]; then
    echo -e "${YELLOW}Multiple features need documentation:${NC}"
    for feature in $FEATURES_NEEDING_DOCS; do
      if [ -n "$feature" ]; then
        echo "  - $feature"
      fi
    done
    echo ""
    echo -e "${YELLOW}Consider creating documentation for each feature.${NC}"
    echo -e "   You can use aider: ${GREEN}aider --model ${AIDER_MODEL}${NC}"
    echo ""
  fi

  echo -e "${RED}❌  Commit blocked: Feature documentation needs updating${NC}"
  echo ""
  echo "Please create or update the relevant documentation before committing."
  echo "See CLAUDE.md 'Feature Documentation Requirements' for details."
  echo ""
  exit 1
else
  echo -e "${GREEN}✅ All changed feature files have corresponding documentation${NC}"
fi

echo ""
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}✅ Feature documentation check passed${NC}"
exit 0
