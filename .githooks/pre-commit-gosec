#!/bin/bash
# Pre-commit hook that runs gosec security scanner on staged Go files
#
# This hook detects security issues:
# - Hardcoded credentials and API keys
# - SQL injection vulnerabilities
# - Weak cryptographic functions
# - Unsafe file operations
# - Command injection risks
#
# Requires: gosec (install with: go install github.com/securego/gosec/v2/cmd/gosec@latest)
#
# Installation: Included in .githooks/pre-commit

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BLUE}  Running gosec security scan${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

# Check if gosec is installed
if ! command -v gosec &> /dev/null; then
  echo -e "${YELLOW}⚠️  gosec not installed, skipping security scan${NC}"
  echo ""
  echo "Install with:"
  echo "  go install github.com/securego/gosec/v2/cmd/gosec@latest"
  echo ""
  exit 0
fi

# Get staged Go files (excluding test files and vendor)
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=d 2>/dev/null | grep '\.go$' | grep -v '_test\.go$' | grep -v '/vendor/' || true)

if [ -z "$STAGED_GO_FILES" ]; then
  echo -e "${GREEN}✅ No Go source files staged for security scan${NC}"
  exit 0
fi

cd "$(git rev-parse --show-toplevel)"

# Convert to space-separated list for gosec
FILES_TO_CHECK=""
for file in $STAGED_GO_FILES; do
  if [ -f "$file" ]; then
    # Skip generated code
    if grep -q "^// Code generated" "$file" 2>/dev/null; then
      continue
    fi
    FILES_TO_CHECK="$FILES_TO_CHECK $file"
  fi
done

if [ -z "$FILES_TO_CHECK" ]; then
  echo -e "${GREEN}✅ No files to scan${NC}"
  exit 0
fi

echo "Scanning files:"
echo "$FILES_TO_CHECK" | tr ' ' '\n' | grep -v '^$' | sed 's/^/  /'
echo ""

# Run gosec on staged files
# Focus on high-impact rules for speed
GOSEC_OUTPUT=$(gosec -quiet -fmt=terminal "$FILES_TO_CHECK" 2>&1) || true

# Check for actual issues (gosec returns non-zero if issues found)
if echo "$GOSEC_OUTPUT" | grep -q "Files: [0-9]"; then
  # Summary line exists, check if any issues
  ISSUE_COUNT=$(echo "$GOSEC_OUTPUT" | grep -E "^\[|^  " | wc -l | tr -d ' ')

  if [ "$ISSUE_COUNT" -gt 0 ]; then
    echo -e "${RED}❌ gosec found potential security issues:${NC}"
    echo ""
    echo "$GOSEC_OUTPUT"
    echo ""
    echo -e "${YELLOW}Review these issues before committing.${NC}"
    echo -e "${BLUE}Note: Some findings may be false positives.${NC}"
    echo ""

    # Check for high-severity issues (hardcoded credentials, etc.)
    if echo "$GOSEC_OUTPUT" | grep -qiE "G101|G102|G401|G402|G501"; then
      echo -e "${RED}⚠️  High-severity issues detected (credentials/crypto/binding)${NC}"
      echo "   These should be fixed before committing."
      echo ""
      exit 1
    fi

    # For medium/low severity, warn but allow commit
    echo -e "${YELLOW}⚠️  Medium/low severity issues found.${NC}"
    echo "   Consider addressing these, but commit is allowed."
    echo ""
    exit 0
  fi
fi

echo -e "${GREEN}✅ gosec found no security issues${NC}"
exit 0
