#!/bin/bash
# Pre-commit hook that verifies setter nil-safety
#
# This hook ensures all Set* methods on tool structs are nil-safe,
# preventing typed-nil interface panics at runtime.
#
# Per CLAUDE.md coding practices:
# "Every Set* method on a tool/service struct that accepts an
# interface or pointer type MUST include a nil guard"
#
# Installation: Included in .githooks/pre-commit

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BLUE}  Verifying setter nil-safety${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

# Check if setters_test.go has been modified or if any tool files changed
STAGED_FILES=$(git diff --cached --name-only --diff-filter=d 2>/dev/null || true)

# Check if any relevant files are staged
RELEVANT_CHANGED=false
for file in $STAGED_FILES; do
  if [[ "$file" == *"_test.go" ]] || [[ "$file" == "internal/tools/"* ]]; then
    RELEVANT_CHANGED=true
    break
  fi
done

if [ "$RELEVANT_CHANGED" = false ]; then
  echo -e "${GREEN}✅ No relevant changes to verify${NC}"
  exit 0
fi

# Run the setters test
echo "Running setters nil-safety test..."
echo ""

cd "$(git rev-parse --show-toplevel)"

if go test ./internal/tools/builtin/... -run TestAllSetters_NilSafe -v 2>&1; then
  echo ""
  echo -e "${GREEN}✅ All setters are nil-safe${NC}"
  exit 0
else
  echo ""
  echo -e "${RED}❌ Setter nil-safety test failed${NC}"
  echo ""
  echo -e "${YELLOW}Add nil guards to Set* methods:${NC}"
  echo ""
  echo "  // WRONG: direct assignment allows typed-nil panic"
  echo "  func (t *SomeTool) SetFenceChecker(fc FenceChecker) {"
  echo "      t.fenceChecker = fc  // fc could be a typed-nil interface"
  echo "  }"
  echo ""
  echo "  // RIGHT: nil guard prevents typed-nil panic"
  echo "  func (t *SomeTool) SetFenceChecker(fc FenceChecker) {"
  echo "      if fc != nil {"
  echo "          t.fenceChecker = fc"
  echo "      }"
  echo "  }"
  echo ""
  echo -e "${BLUE}See: CLAUDE.md 'Typed-nil interface guard'${NC}"
  echo ""
  exit 1
fi
