#!/bin/bash
# Pre-commit hook that runs go vet on staged Go packages
#
# This hook detects common Go bugs using the built-in vet tool:
# - Unreachable code
# - Invalid printf format strings
# - Possible nil pointer dereferences
# - Shadowed variables
# - And more...
#
# Installation: Included in .githooks/pre-commit

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BLUE}  Running go vet on staged packages${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

# Get staged Go files (excluding test files for speed)
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=d 2>/dev/null | grep '\.go$' | grep -v '_test\.go$' || true)

if [ -z "$STAGED_GO_FILES" ]; then
  echo -e "${GREEN}✅ No Go source files staged${NC}"
  exit 0
fi

# Get unique package directories
PACKAGES=$(echo "$STAGED_GO_FILES" | xargs -I{} dirname {} | sort -u | sed 's|^|./|')

if [ -z "$PACKAGES" ]; then
  echo -e "${GREEN}✅ No packages to vet${NC}"
  exit 0
fi

echo "Checking packages:"
echo "$PACKAGES" | sed 's/^/  /'
echo ""

# Run go vet on each package
VET_FAILED=false
VET_OUTPUT=""

for pkg in $PACKAGES; do
  # Skip vendor and generated code
  if echo "$pkg" | grep -q "/vendor/\|/zz_generated\|\.pb\.go"; then
    continue
  fi

  # Run vet and capture output
  if vet_result=$(go vet "$pkg" 2>&1); then
    continue
  else
    VET_FAILED=true
    VET_OUTPUT="${VET_OUTPUT}${pkg}:\n${vet_result}\n\n"
  fi
done

if [ "$VET_FAILED" = true ]; then
  echo -e "${RED}❌ go vet found issues:${NC}"
  echo ""
  echo -e "$VET_OUTPUT"
  echo ""
  echo -e "${YELLOW}Fix these issues before committing.${NC}"
  echo -e "${BLUE}Tip: Run 'go vet ./...' to see all issues${NC}"
  echo ""
  exit 1
fi

echo -e "${GREEN}✅ go vet passed - no issues found${NC}"
exit 0
