// Agent definitions for the Meept multi-agent system
{
  agents: [
    {
      id: "dispatcher",
      name: "Dispatcher",
      role: "dispatcher",
      description: "Intake agent that classifies user intent and routes to specialists",
      model: "",
      enabled: true,
      can_delegate: true,
      additional_tools: ["delegate_task"],
      capabilities: ["reasoning"],
      prompt_components: [
        "base.constitution",
        "base.restrictions",
        "dispatcher.purpose",
        "dispatcher.routing_rules",
        "capabilities.memory",
        "capabilities.platform",
      ],
      constraints: {
        max_iterations: 5,
        timeout_seconds: 60,
        max_tokens_per_turn: 2048,
        max_memory_refs: 10,
      },
    },
    {
      id: "chat",
      name: "Chat",
      role: "conversational",
      description: "Conversational agent for casual chat - delegates tool-requiring tasks to specialists",
      model: "",
      enabled: true,
      can_delegate: true,
      additional_tools: ["web_fetch"],
      capabilities: [],
      prompt_components: [
        "base.constitution",
        "base.restrictions",
        "chat.personality",
        "chat.delegation_rules",
        "capabilities.memory",
      ],
      constraints: {
        max_iterations: 3,
        timeout_seconds: 60,
        max_tokens_per_turn: 4096,
        max_memory_refs: 10,
      },
    },
    {
      id: "coder",
      name: "Code Specialist",
      role: "executor",
      description: "Writes, modifies, and explains code",
      model: "",
      enabled: true,
      can_delegate: false,
      additional_tools: ["file_read", "file_write", "file_delete", "list_directory", "shell_execute"],
      capabilities: ["code", "reasoning"],
      prompt_components: [
        "base.constitution",
        "base.restrictions",
        "base.task_principles",
        "specialist.coder",
        "conditional.code_style",
        "capabilities.memory",
        "capabilities.tasks",
      ],
      constraints: {
        max_iterations: 15,
        timeout_seconds: 600,
        max_tokens_per_turn: 4096,
        max_memory_refs: 20,
      },
    },
    {
      id: "debugger",
      name: "Debugger",
      role: "executor",
      description: "Investigates and fixes bugs, analyzes errors",
      model: "",
      enabled: true,
      can_delegate: false,
      additional_tools: ["file_read", "file_write", "shell_execute", "list_directory"],
      capabilities: ["code", "reasoning"],
      prompt_components: [
        "base.constitution",
        "base.restrictions",
        "base.task_principles",
        "specialist.debugger",
        "conditional.error_context",
        "capabilities.memory",
        "capabilities.tasks",
      ],
      constraints: {
        max_iterations: 20,
        timeout_seconds: 900,
        max_tokens_per_turn: 4096,
        max_memory_refs: 20,
      },
    },
    {
      id: "researcher",
      name: "Research Specialist",
      role: "executor",
      description: "Gathers information from web, documentation, and codebase",
      model: "",
      enabled: true,
      can_delegate: false,
      additional_tools: ["web_fetch", "file_read", "list_directory", "shell_execute"],
      capabilities: ["reasoning"],
      prompt_components: [
        "base.constitution",
        "base.restrictions",
        "base.task_principles",
        "specialist.researcher",
        "conditional.source_evaluation",
        "capabilities.memory",
        "capabilities.tasks",
      ],
      constraints: {
        max_iterations: 15,
        timeout_seconds: 600,
        max_tokens_per_turn: 4096,
        max_memory_refs: 15,
      },
    },
    {
      id: "analyst",
      name: "Analysis Specialist",
      role: "executor",
      description: "Performs deep analysis, summarization, and synthesis of information",
      model: "",
      enabled: true,
      can_delegate: false,
      additional_tools: ["file_read", "list_directory"],
      capabilities: ["reasoning"],
      prompt_components: [
        "base.constitution",
        "base.restrictions",
        "base.task_principles",
        "specialist.analyst",
        "conditional.analysis_depth",
        "capabilities.memory",
        "capabilities.tasks",
      ],
      constraints: {
        max_iterations: 10,
        timeout_seconds: 600,
        max_tokens_per_turn: 4096,
        max_memory_refs: 20,
      },
    },
    {
      id: "planner",
      name: "Planning Specialist",
      role: "executor",
      description: "Decomposes complex tasks, creates execution plans",
      model: "",
      enabled: true,
      can_delegate: false,
      additional_tools: [],
      capabilities: ["reasoning"],
      prompt_components: [
        "base.constitution",
        "base.restrictions",
        "base.task_principles",
        "specialist.planner",
        "conditional.task_decomposition",
        "capabilities.memory",
        "capabilities.tasks",
      ],
      constraints: {
        max_iterations: 8,
        timeout_seconds: 300,
        max_tokens_per_turn: 4096,
        max_memory_refs: 15,
      },
    },
    {
      id: "committer",
      name: "Git Specialist",
      role: "executor",
      description: "Handles git operations: commits, branches, PRs",
      model: "",
      enabled: true,
      can_delegate: false,
      additional_tools: ["shell_execute", "file_read", "list_directory"],
      capabilities: [],
      prompt_components: [
        "base.constitution",
        "base.restrictions",
        "specialist.committer",
        "conditional.git_safety",
        "capabilities.memory",
      ],
      constraints: {
        max_iterations: 5,
        timeout_seconds: 120,
        max_tokens_per_turn: 2048,
        max_memory_refs: 5,
      },
    },
    {
      id: "scheduler",
      name: "Scheduler Specialist",
      role: "executor",
      description: "Schedules tasks, manages reminders and recurring jobs",
      model: "",
      enabled: true,
      can_delegate: false,
      additional_tools: [],
      capabilities: [],
      prompt_components: [
        "base.constitution",
        "base.restrictions",
        "specialist.scheduler",
        "capabilities.memory",
        "capabilities.tasks",
      ],
      constraints: {
        max_iterations: 5,
        timeout_seconds: 60,
        max_tokens_per_turn: 1024,
        max_memory_refs: 5,
      },
    },
  ],
}
