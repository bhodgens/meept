// Menubar app configuration
{
  // Connection to meept daemon (always uses HTTPS)
  "daemon": {
    "http_url": "https://localhost:8081",
    // Default dev API key: use the value from pkg/constants/api_key.go.
    // For production, generate a new key with `meept token generate --save`.
    "api_token": null
  },

  // UI preferences
  "ui": {
    // Show panel in menu bar
    "show_in_menu_bar": true,
    // Start at login
    "start_at_login": false,
    // Menu bar icon style: "icon", "text", "both"
    "icon_style": "icon",
  },

  // Notifications
  "notifications": {
    "enabled": true,
    // Notify on: "all", "errors_only", "none"
    "level": "errors_only",
  },
}
