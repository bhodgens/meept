{
  // Default model for general use (provider/model-id format)
  "model": "zai/glm-4.7",

  // Fast/cheap model for classification, summarization
  // Use "classifier" or "summarizer" aliases for automatic fallback
  "small_model": "local/lfm-1.2b-4bit",  // Best classifier (69.1% accuracy, 2.9% error rate)

  // Model for intent classification (use alias "classifier" for fallback)
  "classifier_model": "classifier",

  // Model for session summarization (use alias "summarizer" for fallback)
  "summarizer_model": "summarizer",

  // Model aliases with cooldown-based failover
  "model_aliases": {
    "classifier": {
      "models": [
        "local/lfm-1.2b-4bit",        // Primary: Best overall (69.1% accuracy, 2.9% error rate, 279ms)
        "local/lfm-thinking-claude",  // Fallback 1: Thinking-Claude (58.8% accuracy, better on plan intent)
        "local/lfm-code",             // Fallback 1: fast local model
        "zai/glm-4.5-air",            // Fallback 2: remote API
        "ollama/llama3.2"             // Fallback 3: local Ollama
      ],
      "timeout": 10,
      "max_fails": 2
    },
    "summarizer": {
      "models": [
        "local/lfm-code",      // Primary: fast local model
        "zai/glm-4.5-air",     // Fallback 1: remote API
        "ollama/llama3.2"      // Fallback 2: local Ollama
      ],
      "timeout": 15,
      "max_fails": 2
    },
    "coder": {
      "models": ["zai/glm-4.7", "ollama/llama3.2"],
      "timeout": 30,
      "max_fails": 3
    },
    "planner": {
      "models": ["zai/glm-4.5-air", "ollama/llama3.2"],
      "timeout": 15,
      "max_fails": 2
    },
    "analyst": {
      "models": ["zai/glm-4.5-air", "ollama/qwen2.5-coder"],
      "timeout": 20,
      "max_fails": 3
    },
    "classifier-test-a": {
      "models": ["local/lfm-combined-sft"],
      "timeout": 30,
      "max_fails": 1
    },
    "classifier-test-b": {
      "models": ["local/lfm-thinking-claude"],
      "timeout": 30,
      "max_fails": 1
    },
    "classifier-test-1.2b-4bit": {
      "models": ["local/lfm-1.2b-4bit"],
      "timeout": 30,
      "max_fails": 1
    },
    "classifier-test-thinking-8bit": {
      "models": ["local/lfm-thinking-8bit"],
      "timeout": 30,
      "max_fails": 1
    },
    "classifier-test-24b-8bit": {
      "models": ["local/lfm-24b-8bit"],
      "timeout": 30,
      "max_fails": 1
    },
    "classifier-test-thinking-bf16": {
      "models": ["local/lfm-thinking-bf16"],
      "timeout": 30,
      "max_fails": 1
    }
  },

  // Default timeout for all providers (in seconds, 50 minutes)
  "default_timeout": 3000,

  // Providers to skip entirely
  "disabled_providers": ["gala-mlx", "gala-llama"],

  "providers": {
    "local": {
      "api": "openai",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "lifecycle": {
        "runtime": "llama-cpp",
        "model_path": "~/models/lfm-code.Q8_0.gguf",
        "auto_start": true,
        "auto_stop_on_exit": true,
        "pid_file": "~/.meept/run/llama.pid",
        "spawn_command": ["llama-server", "-m", "${MODEL_PATH}", "--port", "8080"],
        "spawn_timeout_seconds": 60,
        "health_check": {
          "endpoint": "/health",
          "interval_seconds": 10,
          "timeout_seconds": 5,
          "unhealthy_threshold": 3
        },
        "restart_policy": {
          "enabled": true,
          "max_attempts": 3,
          "cooldown_seconds": 30,
          "reset_after_seconds": 300
        }
      },
      "models": {
        "lfm-code": {
          "name": "LFM2.5-1.2B-Instruct.Q8_0",
          "capabilities": ["completion", "code", "reasoning"],
          "input_cost": 0.0,
          "output_cost": 0.0,
          "context_limit": 8192,
          "max_output": 2048,
          "temperature": 0.7,
          // Max concurrent requests to this model (0 = unlimited)
          // Useful for local LLMs to prevent overwhelming the server
          "max_concurrency": 2
        },
        "lfm-combined-sft": {
          "name": "/Volumes/LLMs/lfm2.5-1.2b-combined-serialized-sft",
          "path": "/Volumes/LLMs/lfm2.5-1.2b-combined-serialized-sft",
          "capabilities": ["completion", "code", "reasoning"],
          "input_cost": 0.0,
          "output_cost": 0.0,
          "context_limit": 8192,
          "max_output": 512,
          "temperature": 0.1
        },
        "lfm-thinking-claude": {
          "name": "/Volumes/LLMs/alexgusevski/LFM2.5-1.2B-Instruct-Thinking-Claude-High-Reasoning-mlx-4Bit",
          "path": "/Volumes/LLMs/alexgusevski/LFM2.5-1.2B-Instruct-Thinking-Claude-High-Reasoning-mlx-4Bit",
          "capabilities": ["completion", "reasoning"],
          "input_cost": 0.0,
          "output_cost": 0.0,
          "context_limit": 8192,
          "max_output": 512,
          "temperature": 0.1
        },
        "lfm-1.2b-4bit": {
          "name": "/Volumes/LLMs/LFM2.5-1.2B-Instruct-MLX-4bit",
          "path": "/Volumes/LLMs/LFM2.5-1.2B-Instruct-MLX-4bit",
          "capabilities": ["completion", "code", "reasoning"],
          "input_cost": 0.0,
          "output_cost": 0.0,
          "context_limit": 8192,
          "max_output": 512,
          "temperature": 0.1
        },
        "lfm-thinking-8bit": {
          "name": "/Volumes/LLMs/lmstudio-community/LFM2.5-1.2B-Thinking-MLX-8bit",
          "path": "/Volumes/LLMs/lmstudio-community/LFM2.5-1.2B-Thinking-MLX-8bit",
          "capabilities": ["completion", "reasoning"],
          "input_cost": 0.0,
          "output_cost": 0.0,
          "context_limit": 8192,
          "max_output": 512,
          "temperature": 0.1
        },
        "lfm-24b-8bit": {
          "name": "/Volumes/LLMs/lmstudio-community/LFM2-24B-A2B-MLX-8bit",
          "path": "/Volumes/LLMs/lmstudio-community/LFM2-24B-A2B-MLX-8bit",
          "capabilities": ["completion", "code", "reasoning"],
          "input_cost": 0.0,
          "output_cost": 0.0,
          "context_limit": 16384,
          "max_output": 512,
          "temperature": 0.1
        },
        "lfm-thinking-bf16": {
          "name": "/Volumes/LLMs/lmstudio-community/LFM2.5-1.2B-Thinking-MLX-bf16",
          "path": "/Volumes/LLMs/lmstudio-community/LFM2.5-1.2B-Thinking-MLX-bf16",
          "capabilities": ["completion", "reasoning"],
          "input_cost": 0.0,
          "output_cost": 0.0,
          "context_limit": 8192,
          "max_output": 512,
          "temperature": 0.1
        }
      }
    },

    "zai": {
      "api": "openai",
      "options": {
        "baseURL": "https://api.z.ai/api/coding/paas/v4",
        "apiKey": "${ZAI_API_KEY}"
      },
      "models": {
        "glm-4.7": {
          "name": "glm-4.7",
          "capabilities": ["completion", "code", "reasoning", "tool_use"],
          "input_cost": 0.0,
          "output_cost": 0.0,
          "context_limit": 128000,
          "max_output": 8192,
          "temperature": 0.7,
          "top_p": 0.9
        },
        "glm-4.5-air": {
          "name": "glm-4.5-air",
          "capabilities": ["completion", "code", "reasoning"],
          "input_cost": 0.0,
          "output_cost": 0.0,
          "context_limit": 32000,
          "max_output": 4096,
          "temperature": 0.7
        }
      }
    },

    "gala-mlx": {
      "api": "openai",
      "options": {
        "baseURL": "http://gala/api/mlx",
        "apiKey": "${GALA_API_KEY}"
      },
      "models": {
        "lfm-thinking": {
          "name": "LFM2.5-1.2B-Thinking-MLX-bf16",
          "capabilities": ["completion", "reasoning"],
          "input_cost": 0.0,
          "output_cost": 0.0,
          "context_limit": 8192,
          "max_output": 2048,
          "temperature": 0.7
        }
      }
    },

    "gala-llama": {
      "api": "openai",
      "options": {
        "baseURL": "http://gala/llama/v1",
        "apiKey": "${GALA_API_KEY}"
      },
      "models": {
        "dolphin-mistral-7b": {
          "name": "dolphin-2.8-mistral-7b-v02-Q4_K_S.gguf",
          "capabilities": ["completion", "code", "reasoning"],
          "input_cost": 0.0,
          "output_cost": 0.0,
          "context_limit": 32768,
          "max_output": 4096,
          "temperature": 0.7
        }
      }
    },

    "ollama": {
      "api": "openai",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "llama3.2": {
          "name": "llama3.2",
          "capabilities": ["code", "tool_use", "reasoning"],
          "input_cost": 0.0,
          "output_cost": 0.0,
          "context_limit": 128000,
          "max_output": 4096,
          "temperature": 0.7
        },
        "qwen2.5-coder": {
          "name": "qwen2.5-coder",
          "capabilities": ["code", "tool_use"],
          "input_cost": 0.0,
          "output_cost": 0.0,
          "context_limit": 32768,
          "max_output": 8192,
          "temperature": 0.7
        }
      }
    }
  }
}
