{
  // Meept Model Presets
  // Reusable parameter presets for different task types
  // Users can override these in ~/.meept/presets.json5

  "presets": {
    "development": {
      "label": "Development",
      "description": "Balanced for coding tasks",
      "params": {
        "temperature": 0.3,
        "top_p": 0.9,
        "frequency_penalty": 0.0,
        "presence_penalty": 0.0
      }
    },
    "debugging": {
      "label": "Debugging",
      "description": "Methodical troubleshooting",
      "params": {
        "temperature": 0.2,
        "top_p": 0.85,
        "frequency_penalty": 0.0,
        "presence_penalty": 0.0
      }
    },
    "planning": {
      "label": "Planning",
      "description": "Structured thinking",
      "params": {
        "temperature": 0.4,
        "top_p": 0.9,
        "frequency_penalty": 0.0,
        "presence_penalty": 0.0
      }
    },
    "creative": {
      "label": "Creative Writing",
      "description": "High creativity mode",
      "params": {
        "temperature": 0.9,
        "top_p": 0.95,
        "frequency_penalty": 0.5,
        "presence_penalty": 0.5
      }
    },
    "research": {
      "label": "Research",
      "description": "Analytical and thorough",
      "params": {
        "temperature": 0.5,
        "top_p": 0.9,
        "frequency_penalty": 0.0,
        "presence_penalty": 0.0
      }
    },
    "fast": {
      "label": "Fast Responses",
      "description": "Quick, concise answers",
      "params": {
        "temperature": 0.3,
        "top_p": 0.8,
        "max_tokens": 1000
      }
    },
    "detailed": {
      "label": "Detailed Analysis",
      "description": "Comprehensive, thorough responses",
      "params": {
        "temperature": 0.5,
        "top_p": 0.9,
        "max_tokens": 8000
      }
    }
  },

  // Default preset applied when none specified
  "default": "development"
}
